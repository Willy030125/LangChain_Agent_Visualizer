# Copy to .env and adjust. Loaded by app/config.py via pydantic-settings.

# --- Ollama (local or remote server) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Default model for the single agent. Must be tool-calling capable and exist
# on the remote server. Available local models: qwen3.5:latest, qwen3:8b,
# qwen3.5:4b, qwen3:4b, qwen2.5:3b
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_TEMPERATURE=0.0
# Context window. Ollama defaults are small (~4k); coding needs more.
OLLAMA_NUM_CTX=8192

# --- Per-role models for the multi-agent orchestrator ---
MODEL_ORCHESTRATOR=qwen3:8b
MODEL_PLANNER=qwen3.5:latest
MODEL_CODER=qwen3.5:latest
MODEL_DEBUGGER=qwen3.5:latest
MODEL_REVIEWER=qwen3.5:4b
MODEL_REPORTER=qwen3.5:4b

# --- Sandbox / execution ---
WORKSPACE_DIR=./workspace
EXEC_TIMEOUT=60
ALLOW_SHELL=true

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
